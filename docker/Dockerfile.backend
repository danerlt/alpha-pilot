FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    gcc \
    && rm -rf /var/lib/apt/lists/*

RUN pip install uv

COPY pyproject.toml .

RUN uv pip install --system -e ".[dev]"

COPY src/ ./src/
COPY scripts/ ./scripts/
RUN chmod +x scripts/start.sh

EXPOSE 8000

# 启动时自动跑迁移再启动 uvicorn
CMD ["bash", "scripts/start.sh"]
