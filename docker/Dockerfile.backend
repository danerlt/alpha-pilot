FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    gcc \
    && rm -rf /var/lib/apt/lists/*

RUN pip install uv

COPY pyproject.toml .

RUN uv pip install --system -e ".[dev]"

COPY src/ ./src/
COPY migrations/ ./migrations/
COPY alembic.ini .
COPY scripts/ ./scripts/

EXPOSE 8000

# ROOT_PATH 由 docker-compose 注入（服务器环境如 /ap-dev，本地为空）
CMD ["sh", "-c", "uvicorn src.app.main:app --host 0.0.0.0 --port 8000 --root-path ${ROOT_PATH:-}"]
