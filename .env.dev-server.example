# 服务器开发环境配置
# 复制此文件为 .env.dev-server 并填写实际值
# 访问: https://www.danerlt.top/ap-dev

TRADING_MODE=testnet

BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_api_secret

LLM_PROVIDER=claude
LLM_API_KEY=your_anthropic_api_key
LLM_MODEL=claude-opus-4-6
LLM_TIMEOUT_SECONDS=30

# docker-compose.dev-server.yml 会覆盖 DATABASE_URL 和 REDIS_URL
DATABASE_URL=postgresql://alphapilot:alphapilot@localhost:5433/alphapilot_dev
REDIS_URL=redis://localhost:6380/0

DB_PASSWORD=alphapilot

# 开发/测试环境默认管理员（后端启动时自动确保存在并设为 active admin）
DEFAULT_ADMIN_EMAIL=danerlt001@gmail.com
DEFAULT_ADMIN_USERNAME=danerlt001
DEFAULT_ADMIN_PASSWORD=Alpha123456@#$

MAX_POSITION_SIZE_PCT=0.20
MAX_DAILY_LOSS_PCT=0.03
MAX_CONSECUTIVE_LOSSES=3
MAX_SINGLE_RISK_PCT=0.01

STRATEGY_LOOP_INTERVAL_MINUTES=15
POSITION_MONITOR_INTERVAL_SECONDS=10

# Plan 5 新 worker (推荐 dev/prod 都启用; 详见 .env.example 注释)
USE_NEW_PIPELINE_WORKER=true
PIPELINE_SYMBOLS=BTCUSDT,ETHUSDT
PIPELINE_TIMEFRAMES=1h
EVENT_SHUTTLE_MAX_FAILED_ATTEMPTS=3
