# =============================================================================
# AlphaPilot 环境变量模板 (唯一模板, 提交 git)
#
# 部署流程:
#   1. 在项目根创建 envs/ 目录 (已 gitignore, 仅本地存档)
#   2. 拷贝本文件到 envs/local.env / envs/dev.env / envs/test.env / envs/prod.env
#   3. 填写真实密钥
#   4. Makefile / 部署脚本通过 --env-file envs/<env>.env 加载
#   5. 直接 `python` 跑应用时, 拷贝 envs/<env>.env 到项目根 .env (dotenv 默认行为)
#
# Claude 严格只读本文件; envs/ 目录与根 .env 为老板专属.
#
# 字段对齐 backend/src/configs/app_configs.py 9 个子配置类。带 [opt] 标记的有
# 合理默认值, 通常不需要在 .env 里覆盖。
# =============================================================================

# ── ServiceConfig ─────────────────────────────────────────────────────────────
ENVIRONMENT=dev               # dev | uat | prod | test | local
LOG_LEVEL=INFO                # [opt] DEBUG | INFO | WARNING | ERROR
UVICORN_WORKER_NUM=2          # [opt] api 进程 uvicorn worker 数; 单机 2-4
FASTAPI_ROOT_PATH=            # [opt] 子路径部署时填 (如 "/api"), 默认空

# ── CORSConfig ────────────────────────────────────────────────────────────────
ENABLE_CORS=true              # [opt]
CORS_ALLOWED_ORIGINS=["*"]    # [opt] JSON 数组; 生产环境填具体域名
CORS_EXPOSE_HEADERS=["X-Request-ID"]  # [opt]

# ── ExchangeConfig ────────────────────────────────────────────────────────────
TRADING_MODE=testnet          # testnet | mainnet
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# ── LLMConfig (OpenAI 兼容协议; 默认 DeepSeek, 可换任意 OpenAI 协议端点) ──────
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=30        # [opt]

# ── PostgreSQLConfig ──────────────────────────────────────────────────────────
# 推荐用 PG_* 字段拼 URI; DATABASE_URL 留空时按 PG_* 拼接, 显式 postgres:// 才覆盖
# 各环境端口示例: local=5442, dev=5433, test=5434, prod=5435
PG_USER=alphapilot
PG_PASSWORD=alphapilot
PG_HOST=localhost
PG_PORT=5442
PG_DB=alphapilot
POOL_SIZE=20                  # [opt]
POOL_MAX_OVERFLOW=20          # [opt]
DB_CONNECT_TIMEOUT=10         # [opt] seconds
PRINT_SQL=false               # [opt] true 时 echo SQL (仅 dev)
DATABASE_URL=                 # [opt] 显式 postgresql:// 覆盖, 否则按 PG_* 拼

# ── RedisConfig ───────────────────────────────────────────────────────────────
# 各环境端口示例: local=6389, dev=6380, test=6381, prod=6382
REDIS_URL=redis://localhost:6389/0

# ── SchedulerConfig ───────────────────────────────────────────────────────────
STRATEGY_LOOP_INTERVAL_MINUTES=15       # 策略循环触发间隔
POSITION_MONITOR_INTERVAL_SECONDS=10    # 持仓监控触发间隔
PIPELINE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
PIPELINE_TIMEFRAMES=1h
APSCHEDULER_JOBS_TABLE=apscheduler_jobs # [opt]
TASK_QUEUE_KEY=alphapilot:tasks         # [opt] Redis list key
EVENT_BUS_CHANNEL=alphapilot:events     # [opt] Redis pub/sub channel 前缀
EVENT_SHUTTLE_BATCH_SIZE=50             # [opt]
EVENT_SHUTTLE_IDLE_SLEEP_SECONDS=0.5    # [opt]
EVENT_SHUTTLE_MAX_FAILED_ATTEMPTS=3     # outbox 行 publish 失败 N 次后写死信
SCHEDULER_GRACEFUL_SHUTDOWN_SECONDS=60  # [opt] SIGTERM 后等 job 收尾的窗口

# ── RiskConfig ────────────────────────────────────────────────────────────────
MAX_POSITION_SIZE_PCT=0.20
MAX_DAILY_LOSS_PCT=0.03
MAX_CONSECUTIVE_LOSSES=3
MAX_SINGLE_RISK_PCT=0.01

# ── SecurityConfig ────────────────────────────────────────────────────────────
# Critical: JWT 签发密钥; 生成: openssl rand -hex 32
APP_AUTH_SECRET_KEY=

# Critical: Fernet 配置加密主密钥 (加密 system_settings 里 BINANCE/LLM API key)
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_CONFIG_MASTER_KEY=

# 默认管理员引导 (仅 dev/test 建议; 留空则跳过)
# WARNING: 真实邮箱/密码绝对不要写到 example.env, 自查 git diff.
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

# ── 兼容字段 (保留向后兼容, 新配置不依赖) ─────────────────────────────────────
DB_PASSWORD=alphapilot        # legacy; 新代码用 PG_PASSWORD
