# =============================================================================
# AlphaPilot 环境变量模板 (唯一模板, 提交 git)
#
# 部署流程:
#   1. 在项目根创建 envs/ 目录 (已 gitignore, 仅本地存档)
#   2. 拷贝本文件到 envs/local.env / envs/dev.env / envs/test.env / envs/prod.env
#   3. 填写真实密钥
#   4. Makefile / 部署脚本通过 --env-file envs/<env>.env 加载
#   5. 直接 `python` 跑应用时, 拷贝 envs/<env>.env 到项目根 .env (dotenv 默认行为)
#
# Claude 严格只读本文件; envs/ 目录与根 .env 为老板专属.
# =============================================================================

# 交易模式: testnet | mainnet
TRADING_MODE=testnet

# Binance API
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# LLM 配置 (OpenAI 兼容协议; 默认 DeepSeek, 可换任意 OpenAI 协议端点)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=30

# 数据库 (各环境端口示例: local=5442, dev=5433, test=5434, prod=5435)
DATABASE_URL=postgresql://alphapilot:alphapilot@localhost:5442/alphapilot

# Redis (各环境端口示例: local=6389, dev=6380, test=6381, prod=6382)
REDIS_URL=redis://localhost:6389/0

# DB 密码 (生产用强密码)
DB_PASSWORD=alphapilot

# 默认管理员引导 (仅 dev/test 建议; 留空则跳过)
# WARNING: 真实邮箱/密码绝对不要写到 example.env, 自查 git diff.
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

# Critical: JWT 签发密钥
# 生成: openssl rand -hex 32
APP_AUTH_SECRET_KEY=

# Critical: Fernet 配置加密主密钥 (加密 system_settings 里 BINANCE/LLM API key)
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_CONFIG_MASTER_KEY=

# 风控默认参数
MAX_POSITION_SIZE_PCT=0.20
MAX_DAILY_LOSS_PCT=0.03
MAX_CONSECUTIVE_LOSSES=3
MAX_SINGLE_RISK_PCT=0.01

# APScheduler
STRATEGY_LOOP_INTERVAL_MINUTES=15
POSITION_MONITOR_INTERVAL_SECONDS=10

# Pipeline worker (V1)
PIPELINE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
PIPELINE_TIMEFRAMES=1h

# EventShuttle: 一条 outbox 行 publish 失败多少次后写入 dead-letter stream
# (避免无限重试卡住整个 outbox). 0 / 负数等同关闭重试 (首次失败即死信).
EVENT_SHUTTLE_MAX_FAILED_ATTEMPTS=3
