# 生产环境配置（谨慎填写真实 API Key）
# 复制此文件为 .env.prod 并填写实际值
# 访问: https://www.danerlt.top/ap

TRADING_MODE=mainnet

BINANCE_API_KEY=your_mainnet_api_key
BINANCE_API_SECRET=your_mainnet_api_secret

LLM_PROVIDER=claude
LLM_API_KEY=your_anthropic_api_key
LLM_MODEL=claude-opus-4-6
LLM_TIMEOUT_SECONDS=30

DATABASE_URL=postgresql://alphapilot:your_strong_password@localhost:5435/alphapilot_prod
REDIS_URL=redis://localhost:6382/0

DB_PASSWORD=your_strong_password

MAX_POSITION_SIZE_PCT=0.20
MAX_DAILY_LOSS_PCT=0.03
MAX_CONSECUTIVE_LOSSES=3
MAX_SINGLE_RISK_PCT=0.01

STRATEGY_LOOP_INTERVAL_MINUTES=15
POSITION_MONITOR_INTERVAL_SECONDS=10

# Plan 5 新 worker (生产环境也应启用; 详见 .env.example 注释)
USE_NEW_PIPELINE_WORKER=true
PIPELINE_SYMBOLS=BTCUSDT,ETHUSDT
PIPELINE_TIMEFRAMES=1h
EVENT_SHUTTLE_MAX_FAILED_ATTEMPTS=3
